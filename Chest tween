    chestButtons = {}
    
    local chests = getChests()
    for i, chest in ipairs(chests) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, -6, 0, 26)
        btn.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
        btn.Text = chest.Name .. " #" .. i
        btn.TextColor3 = Color3.new(1, 1, 1)
        btn.TextSize = 10
        btn.Font = Enum.Font.Gotham
        btn.Parent = scrollFrame
        
        local bc = Instance.new("UICorner")
        bc.CornerRadius = UDim.new(0, 4)
        bc.Parent = btn
        
        btn.MouseButton1Click:Connect(function()
            stopAuto()
            if not manualEnabled then
                manualEnabled = true
                manualBtn.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
                manualBtn.Text = "Manual: ON"
            end
            local pos = getChestPos(chest)
            if pos then smoothFlyTo(pos) end
        end)
        
        table.insert(chestButtons, btn)
    end
    
    scrollFrame.CanvasSize = UDim2.new(0, 0, 0, #chests * 29)
end

-- ========== إخفاء/إظهار ==========
local guiVisible = true
hideBtn.MouseButton1Click:Connect(function()
    guiVisible = not guiVisible
    local items = {scrollFrame, manualBtn, autoBtn, speedLabel, speedInput, speedFrame}
    for _, item in ipairs(items) do
        item.Visible = guiVisible
    end
    if guiVisible then
        hideBtn.Text = "-"
        mainFrame.Size = UDim2.new(0, 200, 0, 280)
    else
        hideBtn.Text = "+"
        mainFrame.Size = UDim2.new(0, 200, 0, 28)
    end
end)

-- ========== اختصارات ==========
speedInput.FocusLost:Connect(function()
    local num = tonumber(speedInput.Text)
    if num then
        tweenSpeed = math.clamp(num, 10, 400) -- ⭐ الحد الأقصى 400
        speedInput.Text = tostring(tweenSpeed)
        speedLabel.Text = "Speed: " .. tweenSpeed
    end
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and input.KeyCode == Enum.KeyCode.R then
        updateList()
    end
end)

-- ========== تحديث تلقائي + Respawn ==========
task.spawn(function()
    while true do
        updateList()
        task.wait(2)
    end
end)

player.CharacterAdded:Connect(function(char)
    char:WaitForChild("HumanoidRootPart")
    if autoEnabled then
        task.wait(0.5)
        startAuto()
    end
end)
