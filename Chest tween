-- Check if real Sea Beast
local function IsRealSeaBeast(obj)
    if not obj or not obj:IsA("Model") then return false end
    local name = obj.Name
    local isBeast = false
    for _, pattern in ipairs(SB_BeastNames) do
        if name == pattern or name:find("Sea Beast") or name:find("SeaBeast") or name:find("Sea_Beast") then
            isBeast = true
            break
        end
    end
    if not isBeast then return false end
    if name:find("SpawnPoint") or name:find("Spawn") or name:find("Spawner") or name:find("Indicator") then return false end
    if obj.PrimaryPart then return true end
    for _, p in ipairs(obj:GetDescendants()) do
        if p:IsA("BasePart") then return true end
    end
    return false
end

-- Scan for beasts
local function SB_Scan()
    local beasts = {}
    local checked = {}
    for _, obj in ipairs(workspace:GetChildren()) do
        if IsRealSeaBeast(obj) and not checked[obj] then
            checked[obj] = true
            table.insert(beasts, obj)
        end
    end
    for _, obj in ipairs(workspace:GetDescendants()) do
        if IsRealSeaBeast(obj) and not checked[obj] then
            checked[obj] = true
            table.insert(beasts, obj)
        end
    end
    return beasts
end

-- Get main body part (largest part = body)
local function SB_GetBodyPart(obj)
    if not obj or not obj.Parent then return nil end
    if obj.PrimaryPart then return obj.PrimaryPart end
    local biggest = nil
    local maxSize = 0
    for _, p in ipairs(obj:GetDescendants()) do
        if p:IsA("BasePart") then
            local size = p.Size.X * p.Size.Y * p.Size.Z
            if size > maxSize then
                maxSize = size
                biggest = p
            end
        end
    end
    return biggest
end

-- Get beast position safely
local function SB_GetBeastPos(obj)
    local part = SB_GetBodyPart(obj)
    if part then return part.Position end
    return nil
end

-- Attack function (rapid)
local function SB_Attack()
    local char = player.Character
    if not char then return end
    if SB_Config.AutoEquip then
        local tool = char:FindFirstChildOfClass("Tool")
        if not tool then
            local bp = player:FindFirstChild("Backpack")
            if bp then
                for _, t in ipairs(bp:GetChildren()) do
                    if t:IsA("Tool") then
                        t.Parent = char
                        task.wait(0.05)
                        break
                    end
                end
            end
        end
    end
    local tool = char:FindFirstChildOfClass("Tool")
    if tool then 
        pcall(function() tool:Activate() end)
    end
    pcall(function() if mouse1click then mouse1click() end end)
end

-- STICK ON TOP OF BEAST (8 studs above, looks down at it)
local function SB_StartChase(beastPart)
    if SB_ChaseConn then SB_ChaseConn:Disconnect() SB_ChaseConn = nil end
    
    SB_ChaseConn = RunService.Heartbeat:Connect(function()
        if not SB_Running or not SB_Config.Enabled then
            if SB_ChaseConn then SB_ChaseConn:Disconnect() SB_ChaseConn = nil end
            return
        end
        
        if not beastPart or not beastPart.Parent then
            SB_StatusSub.Text = "Sea Beast disappeared! Searching..."
            SB_CurrentTarget = nil
            if SB_ChaseConn then SB_ChaseConn:Disconnect() SB_ChaseConn = nil end
            return
        end

        local char = player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp or not hrp.Parent then return end

        local beastPos = beastPart.Position
        -- 8 studs above, facing down at the beast
        local targetPos = beastPos + Vector3.new(0, 8, 0)
        if targetPos.Y < 10 then
            targetPos = Vector3.new(targetPos.X, 10, targetPos.Z)
        end

        hrp.CFrame = CFrame.new(targetPos, beastPos)
        hrp.AssemblyLinearVelocity = Vector3.zero
        hrp.RotVelocity = Vector3.zero
    end)
end

-- RAPID ATTACK CONNECTION
local function SB_StartAttack()
    if SB_AttackConn then SB_AttackConn:Disconnect() SB_AttackConn = nil end
    
    SB_AttackConn = RunService.Heartbeat:Connect(function()
        if not SB_Running or not SB_Config.Enabled or not SB_CurrentTarget then
            return
        end
        if SB_Config.AutoAttack then
            SB_Attack()
        end
    end)
end

-- Main loop (SEARCH ONLY)
local function SB_Loop()
    while SB_Running and SB_Config.Enabled do
        if SB_CurrentTarget and SB_CurrentTarget.Parent then
            local beastPos = SB_GetBeastPos(SB_CurrentTarget)
            if beastPos then
                SB_StatusSub.Text = "ON: " .. SB_CurrentTarget.Name .. " | STICKING + ATTACKING!"
                task.wait(0.5)
            else
                SB_StatusSub.Text = "Lost target position..."
                SB_CurrentTarget = nil
                if SB_ChaseConn then SB_ChaseConn:Disconnect() SB_ChaseConn = nil end
                task.wait(0.5)
            end
        else
            if SB_ChaseConn then SB_ChaseConn:Disconnect() SB_ChaseConn = nil end
            SB_CurrentTarget = nil
            
            local beasts = SB_Scan()
            if #beasts == 0 then
                SB_StatusSub.Text = "Scanning for Sea Beast..."
                task.wait(1)
            else
                local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                local closest = nil
                local minD = math.huge

                for _, b in ipairs(beasts) do
                    local part = SB_GetBodyPart(b)
                    if part and hrp then
                        local d = (hrp.Position - part.Position).Magnitude
                        if d < minD then
                            minD = d
                            closest = b
                        end
                    end
                end

                if closest then
                    local bodyPart = SB_GetBodyPart(closest)
                    if bodyPart then
                        SB_CurrentTarget = closest
                        SB_StatusSub.Text = "Found: " .. closest.Name .. " | Sticking..."
                        SB_StartChase(bodyPart)
                        SB_StartAttack()
                    end
                end
                task.wait(0.5)
            end
        end
    end
end

function StartSeaBeastFarm()
    if SB_Running then return end
    SB_Running = true
    SB_CurrentTarget = nil
    print("[NAZK] Sea Beast Farm Started! | Sticking on top + Rapid Attack!")
    SB_StartAttack()
    task.spawn(SB_Loop)
end

function StopSeaBeastFarm()
    SB_Running = false
    SB_Config.Enabled = false
    SB_CurrentTarget = nil
    if SB_ChaseConn then SB_ChaseConn:Disconnect() SB_ChaseConn = nil end
    if SB_AttackConn then SB_AttackConn:Disconnect() SB_AttackConn = nil end
    print("[NAZK] Sea Beast Farm Stopped")
end

player.CharacterAdded:Connect(function(char)
    task.delay(1, function()
        if SB_Config.Enabled then StartSeaBeastFarm() end
    end)
end)

print("[NAZK] Universal Auto Farm Loaded! | Speed: 210 | No Cooldown")
