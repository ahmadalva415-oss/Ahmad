-- SERVER HOP SYSTEM
-- ============================================================
local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")
local placeId = game.PlaceId
local jobId = game.JobId

local ServerHop_Config = {
    MaxPlayers = 1,
    RetryDelay = 2,
    RetryLimit = 10
}

local isHopping = false
local visitedServers = {}

local function getServers(cursor)
    local url = ("https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Asc&limit=100"):format(placeId)
    if cursor then
        url = url .. "&cursor=" .. cursor
    end

    local success, result = pcall(function()
        return game:HttpGet(url)
    end)

    if success then
        return HttpService:JSONDecode(result)
    else
        warn("[NAZK] Failed to fetch servers: " .. tostring(result))
        return nil
    end
end

local function findLowPlayerServer()
    local allServers = {}
    local cursor = nil
    local pages = 0

    repeat
        local data = getServers(cursor)
        if not data then break end

        for _, server in ipairs(data.data) do
            if server.id ~= jobId and server.playing <= ServerHop_Config.MaxPlayers then
                if not visitedServers[server.id] then
                    table.insert(allServers, server)
                end
            end
        end

        cursor = data.nextPageCursor
        pages = pages + 1
        task.wait(0.1)
    until not cursor or pages >= 5 or #allServers >= 20

    -- Sort by lowest player count first
    table.sort(allServers, function(a, b)
        return a.playing < b.playing
    end)

    return allServers
end

local function serverHop()
    if isHopping then return end
    isHopping = true

    local tries = 0
    local servers = {}

    repeat
        servers = findLowPlayerServer()
        tries = tries + 1

        if #servers == 0 then
            task.wait(ServerHop_Config.RetryDelay)
        end
    until #servers > 0 or tries >= ServerHop_Config.RetryLimit

    if #servers > 0 then
        local target = servers[1]
        visitedServers[target.id] = true
        print("[NAZK] Hopping to server with " .. target.playing .. " player(s) | JobId: " .. target.id)
        TeleportService:TeleportToPlaceInstance(placeId, target.id, player)
    else
        warn("[NAZK] No low-player servers found after " .. tries .. " attempts.")
        isHopping = false
    end
end

local function serverHopRandom()
    if isHopping then return end
    isHopping = true

    local allServers = {}
    local cursor = nil
    local pages = 0

    repeat
        local data = getServers(cursor)
        if not data then break end

        for _, server in ipairs(data.data) do
            if server.id ~= jobId and not visitedServers[server.id] then
                table.insert(allServers, server)
            end
        end

        cursor = data.nextPageCursor
        pages = pages + 1
        task.wait(0.1)
    until not cursor or pages >= 5

    if #allServers > 0 then
        local target = allServers[math.random(1, #allServers)]
        visitedServers[target.id] = true
        print("[NAZK] Hopping to random server | Players: " .. target.playing .. " | JobId: " .. target.id)
        TeleportService:TeleportToPlaceInstance(placeId, target.id, player)
    else
        warn("[NAZK] No available servers found.")
        isHopping = false
    end
end
