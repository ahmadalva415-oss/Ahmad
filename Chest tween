        Size = UDim2.new(0.5, 0, 0, 20),
        Position = UDim2.new(0.5, 0, 0, 0),
        Font = Enum.Font.GothamBold,
        Text = tostring(default) .. (suffix or ""),
        TextColor3 = CONFIG.Theme.Accent,
