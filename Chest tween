-- ESP Update Function
local function UpdateESPSettings()
    for targetPlayer, data in pairs(ESP_Data) do
        if data.Billboard and data.Billboard.Parent then
            local bg = data.Billboard:FindFirstChild("BG")
            if bg then
                local nameLabel = bg:FindFirstChild("NameLabel")
                local hpBg = bg:FindFirstChild("HP_Bg")
                local itemsLabel = bg:FindFirstChild("ItemsLabel")
                local distLabel = bg:FindFirstChild("DistLabel")

                if nameLabel then nameLabel.Visible = CONFIG.ESP.ShowName end
                if hpBg then hpBg.Visible = CONFIG.ESP.ShowHealth end
                if itemsLabel then itemsLabel.Visible = CONFIG.ESP.ShowItems end
                if distLabel then distLabel.Visible = CONFIG.ESP.ShowDistance end
            end
            -- Update size
            local baseSize = data.BaseSize
            if baseSize then
                data.Billboard.Size = UDim2.new(0, baseSize.X.Offset * CONFIG.ESP.Size, 0, baseSize.Y.Offset * CONFIG.ESP.Size)
            end
        end
    end
    -- Refresh all ESP when style changes
    if ESP_Enabled then
        for targetPlayer, _ in pairs(ESP_Data) do
            RemoveESPForPlayer(targetPlayer)
        end
        for _, p in ipairs(Players:GetPlayers()) do
            CreateESPForPlayer(p)
        end
    end
end

