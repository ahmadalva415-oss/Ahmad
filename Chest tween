local dashCooldown = false

local function DoDash()
    if dashCooldown then return end
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end

    dashCooldown = true
    CooldownFrame.Size = UDim2.new(1, 0, 1, 0)
    Tween(CooldownFrame, {Size = UDim2.new(0, 0, 1, 0)}, CONFIG.DashCooldown)

    Tween(PulseRing, {Size = UDim2.new(1.4, 0, 1.4, 0), BackgroundTransparency = 1}, 0.3)
    task.delay(0.3, function()
        if PulseRing and PulseRing.Parent then
            PulseRing.Size = UDim2.new(1, 0, 1, 0)
            PulseRing.BackgroundTransparency = 0.8
        end
    end)

    local cam = workspace.CurrentCamera
    local lookDir = cam.CFrame.LookVector
    lookDir = Vector3.new(lookDir.X, 0, lookDir.Z).Unit
    if lookDir.Magnitude == 0 then
        lookDir = root.CFrame.LookVector
        lookDir = Vector3.new(lookDir.X, 0, lookDir.Z).Unit
    end

    local dashVel = Instance.new("BodyVelocity")
    dashVel.Velocity = lookDir * CONFIG.DashPower
    dashVel.MaxForce = Vector3.new(500000, 0, 500000)
    dashVel.P = 50000
    dashVel.Parent = root

    local trail = Instance.new("Trail")
    trail.Lifetime = 0.2
    trail.WidthScale = NumberSequence.new(0.4, 0)
    trail.Color = ColorSequence.new(CONFIG.Theme.Accent, CONFIG.Theme.Accent2)
    trail.LightEmission = 1
    trail.Parent = root
    local att0 = Instance.new("Attachment")
    att0.Position = Vector3.new(0, -2, 0)
    att0.Parent = root
    local att1 = Instance.new("Attachment")
    att1.Position = Vector3.new(0, 2, 0)
    att1.Parent = root
    trail.Attachment0 = att0
    trail.Attachment1 = att1

    task.delay(CONFIG.DashDuration, function()
        if dashVel then dashVel:Destroy() end
        if trail then trail:Destroy() end
        if att0 then att0:Destroy() end
        if att1 then att1:Destroy() end
    end)

    task.delay(CONFIG.DashCooldown, function()
        dashCooldown = false
    end)
end

