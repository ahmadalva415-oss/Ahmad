local function updateList()
    for _, btn in ipairs(chestButtons) do
        btn:Destroy()
    end
    chestButtons = {}
    
    local chests = getChests()
    countLabel.Text = "Found: " .. #chests .. " | Farmed: " .. farmedCount
    
    for i, chest in ipairs(chests) do
        local pos = getChestPos(chest)
        local dist = ""
        local hrp = getHRP()
        if hrp and pos then
            local d = math.floor((hrp.Position - pos).Magnitude)
            dist = " [" .. d .. "m]"
        end
        
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, -6, 0, 24)
        btn.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
        btn.Text = "Chest #" .. i .. dist
        btn.TextColor3 = Color3.new(1, 1, 1)
        btn.TextSize = 10
        btn.Font = Enum.Font.Gotham
        btn.Parent = scrollFrame
        
        local bc = Instance.new("UICorner")
        bc.CornerRadius = UDim.new(0, 4)
        bc.Parent = btn
        
        btn.MouseButton1Click:Connect(function()
            stopAuto()
            local p = getChestPos(chest)
            if p then smoothFlyTo(p) end
        end)
        
        table.insert(chestButtons, btn)
    end
    
    scrollFrame.CanvasSize = UDim2.new(0, 0, 0, #chests * 27)
end

