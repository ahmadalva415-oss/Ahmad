-- Main ESP Creation
function CreateESPForPlayer(targetPlayer)
    if targetPlayer == player then return end
    if ESP_Data[targetPlayer] then return end

    local data = {
        Highlight = nil,
        Billboard = nil,
        HP_Fill = nil,
        BG = nil,
        NameLabel = nil,
        HP_Bg = nil,
        ItemsLabel = nil,
        DistLabel = nil,
        BaseSize = nil,
        Connections = {}
    }
    ESP_Data[targetPlayer] = data

    local function setupCharacter(char)
        if not char then return end

        if data.Highlight and data.Highlight.Parent then data.Highlight:Destroy() end
        if data.Billboard and data.Billboard.Parent then data.Billboard:Destroy() end

        if CONFIG.ESP.Style == "v1" then
            CreateV1ESP(targetPlayer, char, data)
        elseif CONFIG.ESP.Style == "v2" then
            CreateV2ESP(targetPlayer, char, data)
        elseif CONFIG.ESP.Style == "v3" then
            CreateV3ESP(targetPlayer, char, data)
        elseif CONFIG.ESP.Style == "v4" then
            CreateV4ESP(targetPlayer, char, data)
        end

        if data.NameLabel then data.NameLabel.Visible = CONFIG.ESP.ShowName end
        if data.HP_Bg then data.HP_Bg.Visible = CONFIG.ESP.ShowHealth end
        if data.ItemsLabel then data.ItemsLabel.Visible = CONFIG.ESP.ShowItems end
        if data.DistLabel then data.DistLabel.Visible = CONFIG.ESP.ShowDistance end

        local conn = RunService.Heartbeat:Connect(function()
            if not data.Billboard or not data.Billboard.Parent then return end
            if not char or not char.Parent then return end

            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum and data.HP_Fill then
                data.HP_Fill.Size = UDim2.new(math.clamp(hum.Health / hum.MaxHealth, 0, 1), 0, 1, 0)
                if CONFIG.ESP.Style == "v1" then
                    if hum.Health / hum.MaxHealth > 0.6 then
                        data.HP_Fill.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
                    elseif hum.Health / hum.MaxHealth > 0.3 then
                        data.HP_Fill.BackgroundColor3 = Color3.fromRGB(255, 200, 0)
                    else
                        data.HP_Fill.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
                    end
                end
            end

            if data.ItemsLabel then
                local items = {}
                local backpack = targetPlayer:FindFirstChild("Backpack")
                if backpack then
                    for _, tool in ipairs(backpack:GetChildren()) do
                        if tool:IsA("Tool") then
                            table.insert(items, tool.Name)
                        end
                    end
                end
                if char then
                    for _, tool in ipairs(char:GetChildren()) do
                        if tool:IsA("Tool") then
                            table.insert(items, "[H] " .. tool.Name)
                        end
                    end
                end

                if #items > 0 then
                    data.ItemsLabel.Text = table.concat(items, ", ")
                else
                    data.ItemsLabel.Text = "No Items"
                end
            end

            if data.DistLabel then
                local myChar = player.Character
                if myChar and myChar:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("HumanoidRootPart") then
                    local dist = (myChar.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude
                    if CONFIG.ESP.Style == "v4" then
                        data.DistLabel.Text = "⚡ " .. math.floor(dist) .. " studs"
                    elseif CONFIG.ESP.Style == "v2" then
                        data.DistLabel.Text = math.floor(dist) .. "m"
                    else
                        data.DistLabel.Text = math.floor(dist) .. " studs"
                    end
                end
            end
        end)
        table.insert(data.Connections, conn)
    end

    if targetPlayer.Character then
        setupCharacter(targetPlayer.Character)
    end

    local charConn = targetPlayer.CharacterAdded:Connect(setupCharacter)
    table.insert(data.Connections, charConn)
end

function RemoveESPForPlayer(targetPlayer)
    local data = ESP_Data[targetPlayer]
    if not data then return end

    for _, conn in ipairs(data.Connections) do
        pcall(function() conn:Disconnect() end)
    end

    if data.Highlight and data.Highlight.Parent then data.Highlight:Destroy() end
    if data.Billboard and data.Billboard.Parent then data.Billboard:Destroy() end

    ESP_Data[targetPlayer] = nil
end

