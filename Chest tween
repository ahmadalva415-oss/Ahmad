-- ============================================================
-- HAZE SEAS CHEST FARM (Enhanced)
-- ============================================================
local tweenSpeed = 325
local autoEnabled = false
local currentConnection = nil
local visitedChests = {}
local farmedCount = 0

local function getHRP()
    local char = player.Character
    if char then return char:FindFirstChild("HumanoidRootPart") end
    return nil
end

local function getHumanoid()
    local char = player.Character
    if char then return char:FindFirstChildOfClass("Humanoid") end
    return nil
end

local function getChestPos(chest)
    if not chest or not chest.Parent then return nil end
    if chest:IsA("Model") then
        if chest.PrimaryPart then return chest.PrimaryPart.Position end
        for _, part in ipairs(chest:GetDescendants()) do
            if part:IsA("BasePart") then return part.Position end
        end
    elseif chest:IsA("BasePart") then
        return chest.Position
    end
    return nil
end

local function getChests()
    local chests = {}
    for _, obj in ipairs(workspace:GetChildren()) do
        if obj:IsA("Model") and obj.Name == "Chest" then
            table.insert(chests, obj)
        end
    end
    return chests
end

local function isVisited(chestPos)
    if not chestPos then return true end
    for _, visitedPos in ipairs(visitedChests) do
        if (visitedPos - chestPos).Magnitude < 25 then return true end
    end
    return false
end

local function smoothFlyTo(targetPos, onComplete)
    local hrp = getHRP()
    if not hrp then
        if onComplete then task.defer(onComplete) end
        return
    end
    if currentConnection then
        currentConnection:Disconnect()
        currentConnection = nil
    end
    local startCF = hrp.CFrame
    local targetCF = CFrame.new(targetPos + Vector3.new(0, 3, 0))
    local distance = (startCF.Position - targetCF.Position).Magnitude
    local duration = math.max(distance / tweenSpeed, 0.01)
    local startTime = tick()
    if distance < 5 then
        hrp.CFrame = targetCF
        hrp.AssemblyLinearVelocity = Vector3.zero
        if onComplete then task.defer(onComplete) end
        return
    end
    currentConnection = RunService.Heartbeat:Connect(function()
        if not hrp or not hrp.Parent then
            if currentConnection then currentConnection:Disconnect() currentConnection = nil end
            return
        end
        local elapsed = tick() - startTime
        local alpha = elapsed / duration
        if alpha >= 1 then
            hrp.CFrame = targetCF
            hrp.AssemblyLinearVelocity = Vector3.zero
            if currentConnection then currentConnection:Disconnect() currentConnection = nil end
            if onComplete then task.defer(onComplete) end
            return
        end
        alpha = alpha * alpha * (3 - 2 * alpha)
        hrp.CFrame = startCF:Lerp(targetCF, alpha)
        hrp.AssemblyLinearVelocity = Vector3.zero
    end)
end

local function stopAuto()
    if not autoEnabled then return end
    autoEnabled = false
    visitedChests = {}
    farmedCount = 0
    if currentConnection then
        currentConnection:Disconnect()
        currentConnection = nil
    end
    local humanoid = getHumanoid()
    if humanoid then
        humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
        humanoid.AutoRotate = true
    end
end

local function startAuto()
    if autoEnabled then return end
    autoEnabled = true
    visitedChests = {}
    farmedCount = 0
    local function nextChest()
        if not autoEnabled then return end
        local chests = getChests()
        if #chests == 0 then task.defer(nextChest) return end
        local hrp = getHRP()
        if not hrp then task.defer(nextChest) return end
        local bestChest = nil
        local bestDist = math.huge
        for _, chest in ipairs(chests) do
            local pos = getChestPos(chest)
            if pos and not isVisited(pos) then
                local d = (hrp.Position - pos).Magnitude
                if d < bestDist then bestDist = d bestChest = chest end
            end
        end
        if not bestChest then
            visitedChests = {}
            for _, chest in ipairs(chests) do
                local pos = getChestPos(chest)
                if pos then
                    local d = (hrp.Position - pos).Magnitude
                    if d < bestDist then bestDist = d bestChest = chest end
                end
            end
        end
        if not bestChest then bestChest = chests[1] end
        local pos = getChestPos(bestChest)
        if pos then
            table.insert(visitedChests, pos)
            farmedCount = farmedCount + 1
            smoothFlyTo(pos, function()
                if not autoEnabled then return end
                task.defer(nextChest)
            end)
        else
            task.defer(nextChest)
        end
    end
    nextChest()
end

