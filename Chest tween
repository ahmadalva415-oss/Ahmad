    })

    local sliderBg = Create("Frame", {
        Parent = frame,
        BackgroundColor3 = CONFIG.Theme.Background,
        Size = UDim2.new(1, 0, 0, 8),
        Position = UDim2.new(0, 0, 0, 30)
    })
    AddCorner(sliderBg, 4)

