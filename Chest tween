-- Dropdown that renders options in ScreenGui to avoid clipping
local function CreateDropdown(parent, name, options, default, callback)
    local frame = Create("Frame", {
        Parent = parent,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 65)
    })

    Create("TextLabel", {
        Parent = frame,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 20),
        Font = Enum.Font.Gotham,
        Text = name,
        TextColor3 = CONFIG.Theme.Text,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left
    })

    local dropdownBtn = Create("TextButton", {
        Parent = frame,
        BackgroundColor3 = CONFIG.Theme.Background,
        Size = UDim2.new(1, 0, 0, 32),
        Position = UDim2.new(0, 0, 0, 26),
        Font = Enum.Font.GothamBold,
        Text = "  " .. default,
        TextColor3 = CONFIG.Theme.Text,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left,
        AutoButtonColor = false
    })
    AddCorner(dropdownBtn, 6)
    AddStroke(dropdownBtn, CONFIG.Theme.Border, 1)

    local arrow = Create("TextLabel", {
        Parent = dropdownBtn,
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 30, 1, 0),
        Position = UDim2.new(1, -30, 0, 0),
        Font = Enum.Font.GothamBold,
        Text = "▼",
        TextColor3 = CONFIG.Theme.Accent,
        TextSize = 12
    })

    -- Options frame rendered in ScreenGui to avoid clipping inside ScrollingFrame
    local optionsFrame = Create("Frame", {
        Parent = ScreenGui,
        BackgroundColor3 = CONFIG.Theme.Secondary,
        BorderSizePixel = 0,
        Size = UDim2.new(0, 200, 0, 0),
        Position = UDim2.new(0, 0, 0, 0),
        Visible = false,
        ZIndex = 100
    })
    AddCorner(optionsFrame, 6)
    AddStroke(optionsFrame, CONFIG.Theme.Border, 1)
    optionsFrame.ClipsDescendants = false

    local current = default
    local open = false
    local optionButtons = {}

    local function updatePosition()
        if not dropdownBtn or not dropdownBtn.Parent then return end
        local absPos = dropdownBtn.AbsolutePosition
        local absSize = dropdownBtn.AbsoluteSize
        optionsFrame.Position = UDim2.new(0, absPos.X, 0, absPos.Y + absSize.Y + 4)
        optionsFrame.Size = UDim2.new(0, absSize.X, 0, #options * 30)
    end

    for i, opt in ipairs(options) do
        local optBtn = Create("TextButton", {
            Parent = optionsFrame,
            BackgroundColor3 = CONFIG.Theme.Secondary,
            BorderSizePixel = 0,
            Size = UDim2.new(1, 0, 0, 30),
            Position = UDim2.new(0, 0, 0, (i-1) * 30),
            Font = Enum.Font.Gotham,
            Text = "  " .. opt,
            TextColor3 = (opt == default) and CONFIG.Theme.Accent or CONFIG.Theme.Text,
            TextSize = 12,
            TextXAlignment = Enum.TextXAlignment.Left,
            AutoButtonColor = false,
            ZIndex = 101
        })
        table.insert(optionButtons, optBtn)

        optBtn.MouseButton1Click:Connect(function()
            current = opt
            dropdownBtn.Text = "  " .. opt
            open = false
            optionsFrame.Visible = false
            arrow.Text = "▼"
            for _, ob in ipairs(optionButtons) do
                if ob.Text:sub(3) == current then
                    ob.TextColor3 = CONFIG.Theme.Accent
                else
                    ob.TextColor3 = CONFIG.Theme.Text
                end
            end
            if callback then callback(opt) end
        end)

        optBtn.MouseEnter:Connect(function()
            Tween(optBtn, {BackgroundColor3 = CONFIG.Theme.Accent}, 0.1)
            optBtn.TextColor3 = CONFIG.Theme.Text
        end)
        optBtn.MouseLeave:Connect(function()
            if opt ~= current then
                Tween(optBtn, {BackgroundColor3 = CONFIG.Theme.Secondary}, 0.1)
                optBtn.TextColor3 = CONFIG.Theme.Text
            else
                Tween(optBtn, {BackgroundColor3 = CONFIG.Theme.Secondary}, 0.1)
                optBtn.TextColor3 = CONFIG.Theme.Accent
            end
        end)
    end

    dropdownBtn.MouseButton1Click:Connect(function()
        open = not open
        if open then
            updatePosition()
        end
        optionsFrame.Visible = open
        arrow.Text = open and "▲" or "▼"
    end)

    -- Close dropdown when clicking elsewhere
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if open and input.UserInputType == Enum.UserInputType.MouseButton1 then
            local mousePos = input.Position
            local absPos = optionsFrame.AbsolutePosition
            local absSize = optionsFrame.AbsoluteSize
            local inX = mousePos.X >= absPos.X and mousePos.X <= absPos.X + absSize.X
            local inY = mousePos.Y >= absPos.Y and mousePos.Y <= absPos.Y + absSize.Y
            local btnPos = dropdownBtn.AbsolutePosition
            local btnSize = dropdownBtn.AbsoluteSize
            local inBtnX = mousePos.X >= btnPos.X and mousePos.X <= btnPos.X + btnSize.X
            local inBtnY = mousePos.Y >= btnPos.Y and mousePos.Y <= btnPos.Y + btnSize.Y
            if not (inX and inY) and not (inBtnX and inBtnY) then
                open = false
                optionsFrame.Visible = false
                arrow.Text = "▼"
            end
        end
    end)

    return frame
end

