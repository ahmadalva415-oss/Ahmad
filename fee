local function getHRP()
	local char = player.Character
	if char then return char:FindFirstChild("HumanoidRootPart") end
	return nil
end

local function getHumanoid()
	local char = player.Character
	if char then return char:FindFirstChildOfClass("Humanoid") end
	return nil
end

local function getPlayerTeam(plr)
	local char = plr.Character
	if not char then return "Unknown" end
	local head = char:FindFirstChild("Head")
	if head then
		for _, gui in ipairs(head:GetChildren()) do
			if gui:IsA("BillboardGui") and gui.Name:lower():find("hider") then return "Hider" end
			if gui:IsA("BillboardGui") and gui.Name:lower():find("seeker") then return "Seeker" end
		end
	end
	local backpack = plr:FindFirstChild("Backpack")
	if backpack then
		if backpack:FindFirstChild("Blaster") or backpack:FindFirstChild("Shotgun") then return "Seeker" end
	end
	local tool = char:FindFirstChildOfClass("Tool")
	if tool then
		if tool.Name:lower():find("gun") or tool.Name:lower():find("blaster") or tool.Name:lower():find("shotgun") then return "Seeker" end
	end
	return "Hider"
end

