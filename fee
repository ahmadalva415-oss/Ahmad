local function toggleFreeCam(enabled)
	CameraSystem.FreeCam = enabled
	if enabled then
		local camPos = camera.CFrame.Position
		local camRot = camera.CFrame.Rotation
		local input = Vector3.zero
		CameraSystem.FreeCamConnection = RunService.RenderStepped:Connect(function(dt)
			if not CameraSystem.FreeCam then return end
			local move = Vector3.zero
			if UserInputService:IsKeyDown(Enum.KeyCode.W) then move = move + camRot.LookVector end
			if UserInputService:IsKeyDown(Enum.KeyCode.S) then move = move - camRot.LookVector end
			if UserInputService:IsKeyDown(Enum.KeyCode.A) then move = move - camRot.RightVector end
			if UserInputService:IsKeyDown(Enum.KeyCode.D) then move = move + camRot.RightVector end
			if UserInputService:IsKeyDown(Enum.KeyCode.E) then move = move + Vector3.new(0, 1, 0) end
			if UserInputService:IsKeyDown(Enum.KeyCode.Q) then move = move - Vector3.new(0, 1, 0) end
			if move.Magnitude > 0 then
				camPos = camPos + move.Unit * 50 * dt
			end
			local mouseDelta = UserInputService:GetMouseDelta()
			local rx = CFrame.Angles(-math.rad(mouseDelta.Y * 0.3), 0, 0)
			local ry = CFrame.Angles(0, -math.rad(mouseDelta.X * 0.3), 0)
			camRot = camRot * rx * ry
			camera.CFrame = CFrame.new(camPos) * camRot
			camera.CameraType = Enum.CameraType.Scriptable
		end)
	else
		if CameraSystem.FreeCamConnection then CameraSystem.FreeCamConnection:Disconnect() end
		camera.CameraType = Enum.CameraType.Custom
		local char = player.Character
		if char then
			local hrp = char:FindFirstChild("HumanoidRootPart")
			if hrp then camera.CameraSubject = char:FindFirstChildOfClass("Humanoid") or hrp end
		end
	end
end

