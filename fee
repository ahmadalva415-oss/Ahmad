local function getCoins()
	local coins = {}
	local clientCoins = Workspace:FindFirstChild("ClientCoins")
	if clientCoins then
		for _, coin in ipairs(clientCoins:GetChildren()) do
			if coin:IsA("BasePart") or coin:IsA("Model") then
				table.insert(coins, coin)
			end
		end
	end
	return coins
end

local function getCoinPosition(coin)
	if coin:IsA("BasePart") then
		return coin.Position
	elseif coin:IsA("Model") then
		if coin.PrimaryPart then
			return coin.PrimaryPart.Position
		else
			local part = coin:FindFirstChildWhichIsA("BasePart")
			if part then return part.Position end
		end
	end
	return nil
end

local function isCoinCollected(coin)
	return not coin or not coin.Parent
end

