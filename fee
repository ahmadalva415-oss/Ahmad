local function addLightingEffect(name, settings)
	if LightingState.Effects[name] then LightingState.Effects[name]:Destroy() end
	local effect = Instance.new(name)
	for prop, val in pairs(settings) do
		effect[prop] = val
	end
	effect.Parent = Lighting
	LightingState.Effects[name] = effect
end

local function removeLightingEffect(name)
	if LightingState.Effects[name] then
		LightingState.Effects[name]:Destroy()
		LightingState.Effects[name] = nil
	end
end

