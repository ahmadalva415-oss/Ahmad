local function updateESP()
	local hrp = getHRP()
	if not hrp then return end
	local myPos = hrp.Position
	for target, data in pairs(ESP.Objects) do
		if not target or not target.Parent then
			if data.Billboard then data.Billboard:Destroy() end
			ESP.Objects[target] = nil
			continue
		end
		local targetPos = nil
		if data.Type == "Player" then
			local char = target.Character
			if char then
				local th = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Head")
				if th then targetPos = th.Position end
			end
		else
			if target:IsA("Model") then
				local pp = target.PrimaryPart or target:FindFirstChildWhichIsA("BasePart")
				if pp then targetPos = pp.Position end
			elseif target:IsA("BasePart") then
				targetPos = target.Position
			end
		end
		if not targetPos then
			data.Billboard.Enabled = false
			continue
		end
		local distance = (myPos - targetPos).Magnitude
		data.Billboard.Enabled = true
		data.DistLabel.Text = string.format("[%.0fm]", distance)
		if data.Type == "Player" then
			local team = getPlayerTeam(target)
			local color = (team == "Seeker") and ESP.SeekerColor or ESP.HiderColor
			data.Box.BorderColor3 = color
			data.NameLabel.TextColor3 = color
			data.HealthBar.BackgroundColor3 = color
			local char = target.Character
			local humanoid = char and char:FindFirstChildOfClass("Humanoid")
			if humanoid then
				local healthPercent = math.clamp(humanoid.Health / humanoid.MaxHealth, 0, 1)
				data.HealthBar.Size = UDim2.new(healthPercent, 0, 1, 0)
				data.HealthBg.Visible = true
			else
				data.HealthBg.Visible = false
			end
		else
			data.Box.BorderColor3 = data.Color
			data.NameLabel.TextColor3 = data.Color
			data.HealthBg.Visible = false
		end
		if data.Type == "Player" then
			local char = target.Character
			local head = char and char:FindFirstChild("Head")
			if head then
				data.Billboard.Adornee = head
				data.Billboard.StudsOffset = Vector3.new(0, 2.5, 0)
			end
		else
			data.Billboard.Adornee = target:IsA("Model") and (target.PrimaryPart or target:FindFirstChildWhichIsA("BasePart")) or target
			data.Billboard.StudsOffset = Vector3.new(0, 3, 0)
		end
		data.Box.Visible = ESP.Boxes
		data.NameLabel.Visible = ESP.Names
		data.DistLabel.Visible = ESP.Distance
		data.HealthBg.Visible = (data.Type == "Player" and ESP.Health)
		local scale = math.clamp(300 / distance, 0.5, 2)
		data.Box.Size = UDim2.new(0, 50 * scale, 0, 80 * scale)
		data.Box.Position = UDim2.new(0.5, -25 * scale, 0.5, -40 * scale)
	end
end

local function scanPlayersForESP()
	if not ESP.Players then return end
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= player and plr.Character and not ESP.Objects[plr] then
			local esp = createESPObject(plr, "Player")
			esp.Billboard.Parent = player:WaitForChild("PlayerGui")
		end
	end
end

local function scanItemsForESP()
	if not ESP.Items then return end
	local importantNames = {
		"Chest", "Potion", "Shotgun", "Blaster", "Revolver", "Sniper",
		"DailyReward", "SpinWheel", "Coin", "Badge", "Giver", "Golden", "Rainbow", "Inferno"
	}
	for _, obj in ipairs(Workspace:GetDescendants()) do
		if obj:IsA("Model") or obj:IsA("BasePart") then
			local name = obj.Name
			local isImportant = false
			for _, imp in ipairs(importantNames) do
				if name:find(imp) then isImportant = true; break end
			end
			if isImportant and not ESP.Objects[obj] then
				local esp = createESPObject(obj, "Item", ESP.ItemColor)
				esp.Billboard.Parent = player:WaitForChild("PlayerGui")
			end
		end
	end
end

