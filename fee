-- ========== Auto Farm Loop ==========
local function autoFarmLoop()
	while true do
		if AutoFarm.Enabled then
			local hrp = getHRP()
			if hrp then
				local coins = getCoins()
				local closest, minDist = nil, math.huge

				for _, coin in ipairs(coins) do
					local pos = getCoinPosition(coin)
					if pos then
						local dist = (hrp.Position - pos).Magnitude
						if dist < minDist then
							minDist = dist
							closest = coin
						end
					end
				end

				if closest and closest.Parent then
					local targetPos = getCoinPosition(closest)
					if targetPos then
						local distance = (hrp.Position - targetPos).Magnitude
						local duration = math.max(distance / AutoFarm.Speed, 0.5)

						if AutoFarm.CurrentTween then
							AutoFarm.CurrentTween:Cancel()
						end

						-- Smooth tween with Sine easing
						local tween = TweenService:Create(hrp, TweenInfo.new(duration, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
							CFrame = CFrame.new(targetPos + Vector3.new(0, 1.5, 0))
						})
						AutoFarm.CurrentTween = tween
						tween:Play()
						tween.Completed:Wait()
						AutoFarm.CurrentTween = nil

						-- Wait 1 second at coin location
						task.wait(1)

						-- Move to next coin immediately (no ignoring)
					else
						task.wait(0.2)
					end
				else
					task.wait(0.5)
				end
			else
				task.wait(0.5)
			end
		else
			if AutoFarm.CurrentTween then
				AutoFarm.CurrentTween:Cancel()
				AutoFarm.CurrentTween = nil
			end
			task.wait(0.5)
		end
	end
end

AutoFarm.Connection = task.spawn(autoFarmLoop)

